{
    "version": 2,
    "name": "botcall-platinum",
    "buildCommand": "npm install && npm run build --workspace=frontend",
    "outputDirectory": "frontend/dist",
    "framework": "vite",
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "cleanUrls": true
}